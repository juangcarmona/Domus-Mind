---
import { withLocale, type Locale } from '@/lib/i18n';
import type { HeroContent } from '@/lib/content-types';

const { content, locale } = Astro.props as { content: HeroContent; locale: Locale };
const panel = content?.proofPanel;
---
<section class="hero-section homepage-section" id="hero">
  <div class="hero-grid">
    <div class="hero-copy">
      <h1>{content.headline}</h1>
      <p class="hero-support">{content.supportLine}</p>
      <ul class="hero-proof-bullets">
        {content.proofBullets?.map((bullet) => <li>{bullet}</li>)}
      </ul>
      <div class="hero-actions">
        {content.primaryCta && (
          <a class="button" href={withLocale(locale, content.primaryCta.href)}>{content.primaryCta.label}</a>
        )}
        {content.secondaryCta && (
          <a class="button ghost" href={withLocale(locale, content.secondaryCta.href)}>{content.secondaryCta.label}</a>
        )}
      </div>
    </div>
    {panel && (
      <div class="hero-proof-panel">
        <div class="hero-proof-panel__eyebrow">{panel.eyebrow}</div>
        <div class="hero-proof-panel__title">{panel.title}</div>
        <div class="hero-proof-panel__groups">
          {panel.groups.map((group) => (
            <div class="hero-proof-panel__group">
              {group.map((item) => <span>{item}</span>)}
            </div>
          ))}
        </div>
        <p class="hero-proof-panel__caption">{panel.caption}</p>
      </div>
    )}
  </div>
</section>
